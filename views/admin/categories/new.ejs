<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administration: Ny kategori</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="admin-layout">
        <header class="admin-header">
            <h1>Administration</h1>
        </header>

        <aside class="admin-sidebar">
            <nav class="admin-sidebar-nav">
                <a href="/admin/products" class="admin-sidebar-link">Produkter</a>
                <a href="/admin/categories" class="admin-sidebar-link active">Kategorier</a>
            </nav>
        </aside>

        <main class="admin-form-main">
            <h2 class="admin-page-title">Ny kategori</h2>

            <form class="admin-product-form" action="/admin/categories/new" method="POST" enctype="multipart/form-data">

                <div class="admin-form-group">
                    <label for="category-name">Namn</label>
                    <input type="text" id="category-name" name="category-name" placeholder="Ange namn" maxlength="25"
                        required>
                </div>

                <div class="admin-form-group">
                    <label for="category-image">Bild</label>
                    <label for="category-image" class="custom-file-button">Välj bild</label>
                    <input type="file" id="category-image" name="category-image" accept=".png,.jpg,.jpeg" required
                        class="hidden-file-input">
                </div>

                <button type="submit" class="admin-submit-btn">Lägg till</button>
            </form>
        </main>
    </div>

</body>

</html>