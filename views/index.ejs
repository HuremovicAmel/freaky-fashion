<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Freaky Fashion</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>


  <header class="site-header">
    <div class="header-logo">
      <a href="/" class="logo-box">
        <img src="https://placehold.co/600x200/png" alt="Freaky Fashion Logo">
      </a>
    </div>

    <div class="header-tools">
      <form class="search-form" action="/search" method="get">
        <span class="search-icon" aria-hidden="true">🔍</span>
        <input type="search" name="q" placeholder="Sök produkt" aria-label="Sök produkt">
      </form>

      <div class="header-actions">
        <a href="/favorites" class="icon-link favorites-link" aria-label="Favoriter">

          ♥

          <% if (favoriteCount> 0) { %>
            <span class="favorites-count">
              <%= favoriteCount %>
            </span>
            <% } %>

        </a>
        <a href="/basket" class="icon-link basket-link" aria-label="Varukorg">

          🛒

          <% if (cartCount> 0) { %>
            <span class="basket-count">
              <%= cartCount %>
            </span>
            <% } %>

        </a>
        <a href="/login" class="icon-link" aria-label="Logga in">
          👤
        </a>
      </div>
    </div>

    <%- include('./partials/navbar') %>
  </header>
  <main>
    <section class="hero-box">
      <img src="https://placehold.co/600x400.png" alt="hero-bild" class="hero-image">
      <div class="hero-text">
        <h1>Lorem ipsum dolor</h1>
        <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut
          labore
          et dolore magna aliqua.</p>
      </div>
    </section>
    <%- include('./partials/spots') %>

      <%- include('./partials/popular-products') %>
        <section class="benefits-section">
          <div class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                class="bi bi-globe-americas-fill" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                  d="m8 0 .412.01A7.97 7.97 0 0 1 13.29 2a8.04 8.04 0 0 1 2.548 4.382 8 8 0 1 1-15.674 0 8 8 0 0 1 1.361-3.078A8 8 0 0 1 2.711 2 7.96 7.96 0 0 1 8 0m0 1a7 7 0 0 0-5.958 3.324C2.497 6.192 6.669 7.827 6.5 8c-.5.5-1.034.884-1 1.5.07 1.248 2.259.774 2.5 2 .202 1.032-1.051 3 0 3 1.5-.5 3.798-3.186 4-5 .138-1.242-2-2-3.5-2.5-.828-.276-1.055.648-1.5.5S4.5 5.5 5.5 5s1 0 1.5.5c1 .5.5-1 1-1.5.838-.838 3.16-1.394 3.605-2.001A6.97 6.97 0 0 0 8 1" />
              </svg>
            </span>
            <p>Gratis frakt och returer</p>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                class="bi bi-airplane-engines-fill" viewBox="0 0 16 16">
                <path
                  d="M8 0c-.787 0-1.292.592-1.572 1.151A4.35 4.35 0 0 0 6 3v3.691l-2 1V7.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.191l-1.17.585A1.5 1.5 0 0 0 0 10.618V12a.5.5 0 0 0 .582.493l1.631-.272.313.937a.5.5 0 0 0 .948 0l.405-1.214 2.21-.369.375 2.253-1.318 1.318A.5.5 0 0 0 5.5 16h5a.5.5 0 0 0 .354-.854l-1.318-1.318.375-2.253 2.21.369.405 1.214a.5.5 0 0 0 .948 0l.313-.937 1.63.272A.5.5 0 0 0 16 12v-1.382a1.5 1.5 0 0 0-.83-1.342L14 8.691V7.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v.191l-2-1V3c0-.568-.14-1.271-.428-1.849C9.292.591 8.787 0 8 0" />
              </svg>
            </span>
            <p>Expressfrakt</p>
          </div>

          <div class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                class="bi bi-shield-shaded" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                  d="M8 14.933a1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56" />
              </svg>
            </span>
            <p>Säkra betalningar</p>
          </div>

          <div class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                class="bi bi-emoji-smile" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                <path
                  d="M4.285 9.567a.5.5 0 0 1 .683.183A3.5 3.5 0 0 0 8 11.5a3.5 3.5 0 0 0 3.032-1.75.5.5 0 1 1 .866.5A4.5 4.5 0 0 1 8 12.5a4.5 4.5 0 0 1-3.898-2.25.5.5 0 0 1 .183-.683M7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5m4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5" />
              </svg>
            </span>
            <p>Nyheter varje dag</p>
          </div>
        </section>
  </main>
  <footer class="site-footer">
    <div class="footer-accordion">
      <details class="accordion-item" open>
        <summary class="accordion-title">Shopping</summary>
        <div class="accordion-content">
          <a href="#">Vinterjackor</a>
          <a href="#">Pufferjackor</a>
          <a href="#">Kappa</a>
          <a href="#">Trenchcoats</a>
        </div>
      </details>
      <details class="accordion-item">
        <summary class="accordion-title">Mina Sidor</summary>
        <div class="accordion-content">
          <a href="#">Mina Ordrar</a>
          <a href="#">Mitt Konto</a>

        </div>
      </details>
      <details class="accordion-item footer-customer-service">
        <summary class="accordion-title">Kundtjänst</summary>
        <div class="accordion-content">
          <a href="#">Returnpolicy</a>
          <a href="#">Integritetspolicy</a>

        </div>
      </details>
    </div>
    <div class="footer-bottom">
      <p>&copy; Freaky Fashion</p>

    </div>

  </footer>

</body>

</html>